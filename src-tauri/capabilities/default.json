{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "run_claude", "cmd": "claude", "args": true },
        {
          "name": "run_git_clone",
          "cmd": "git",
          "args": ["clone", { "validator": ".*" }]
        },
        {
          "name": "run_git_rev_parse",
          "cmd": "git",
          "args": ["rev-parse", { "validator": ".*" }]
        },
        {
          "name": "run_git_pull",
          "cmd": "git",
          "args": ["pull", { "validator": ".*" }]
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    "dialog:default"
  ]
}
