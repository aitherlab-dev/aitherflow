{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "run_claude", "cmd": "claude", "args": true },
        { "name": "run_git", "cmd": "git", "args": true }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    "dialog:default"
  ]
}
